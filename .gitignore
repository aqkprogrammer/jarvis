# =============================================================================
# JARVIS .gitignore — Python + Node.js + Docker + env files
# =============================================================================

# ---------------------------------------------------------------------------
# Secrets & Environment
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.test
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/
.secrets

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Testing
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
pytestdebug.log

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/
.pyre/

# Linting / formatting
.ruff_cache/

# Distribution
MANIFEST
*.manifest
*.spec
pip-wheel-metadata/

# Jupyter
.ipynb_checkpoints
*.ipynb

# Poetry
poetry.toml

# ---------------------------------------------------------------------------
# Node.js / Next.js
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js
.yarn/

# Next.js
frontend/.next/
frontend/out/
frontend/build/

# Nuxt.js / Vite
.nuxt/
.vite/
.output/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Testing (JS)
coverage/
.nyc_output/
jest_html_reporters_attach/

# ESLint / Prettier
.eslintcache
.prettierignore

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
.dockerignore
docker-compose.override.yml
docker-compose.local.yml

# ---------------------------------------------------------------------------
# Databases & Data
# ---------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
postgres_data/
redis_data/
qdrant_data/

# ---------------------------------------------------------------------------
# Alembic
# ---------------------------------------------------------------------------
database/migrations/versions/__pycache__/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log
*.log.*
log/
npm-debug.log
yarn-error.log

# ---------------------------------------------------------------------------
# Uploads & generated files
# ---------------------------------------------------------------------------
uploads/
media/
static/collected/
*.mp3
*.wav
*.ogg
*.webm
*.mp4

# TTS cache
.tts_cache/

# ---------------------------------------------------------------------------
# IDEs & Editors
# ---------------------------------------------------------------------------
.idea/
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.orig

# JetBrains
*.iml
.idea/
*.iws

# Emacs
*#
*.elc

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V7
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------------------------
# Testing artifacts
# ---------------------------------------------------------------------------
.tox/
.nox/
test-results/
test-reports/
allure-results/

# ---------------------------------------------------------------------------
# Claude Code session files
# ---------------------------------------------------------------------------
.claude/

# ---------------------------------------------------------------------------
# CI/CD
# ---------------------------------------------------------------------------
.github/workflows/secrets/

# ---------------------------------------------------------------------------
# Certificates (generated)
# ---------------------------------------------------------------------------
deployment/nginx/certs/
ssl/
certs/

# ---------------------------------------------------------------------------
# Monitoring data
# ---------------------------------------------------------------------------
prometheus_data/
grafana_data/

# ---------------------------------------------------------------------------
# Model weights (large binary files)
# ---------------------------------------------------------------------------
*.onnx
*.pt
*.pth
*.bin
*.gguf
*.safetensors
models/
!models/.gitkeep
