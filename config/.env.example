# =============================================================================
# JARVIS Environment Configuration Template
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
ENVIRONMENT=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR | CRITICAL
APP_NAME=JARVIS
APP_VERSION=1.0.0
JARVIS_DOMAIN=localhost
API_BASE_URL=http://localhost:8000   # Public base URL (used to build incoming webhook URLs)

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=jarvis
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=change_me_in_production

# Constructed URL (used by SQLAlchemy async)
DATABASE_URL=postgresql+asyncpg://jarvis:change_me_in_production@localhost:5432/jarvis

# Sync URL (used by Alembic migrations)
DATABASE_URL_SYNC=postgresql://jarvis:change_me_in_production@localhost:5432/jarvis

# Pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=                  # Leave empty for no auth

# Celery-specific overrides
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---------------------------------------------------------------------------
# Qdrant (Vector Store)
# ---------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                  # Set for production Qdrant Cloud
QDRANT_COLLECTION_MEMORIES=jarvis_memories
QDRANT_COLLECTION_DOCS=jarvis_documents
QDRANT_VECTOR_SIZE=1536          # Match your embedding model dimensions

# ---------------------------------------------------------------------------
# Security / Auth
# ---------------------------------------------------------------------------
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ---------------------------------------------------------------------------
# AI / LLM Providers
# ---------------------------------------------------------------------------

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...            # Optional

# Groq (fast inference)
GROQ_API_KEY=gsk_...

# Google (Gemini)
GOOGLE_API_KEY=AIza...
GOOGLE_PROJECT_ID=               # For Vertex AI

# Cohere
COHERE_API_KEY=                  # Optional

# ---------------------------------------------------------------------------
# Voice / Speech
# ---------------------------------------------------------------------------

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=el_...
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# AssemblyAI (STT)
ASSEMBLYAI_API_KEY=

# Deepgram (STT)
DEEPGRAM_API_KEY=

# Whisper local model size
WHISPER_MODEL=base

# Picovoice (wake word)
PICOVOICE_ACCESS_KEY=

# Default STT / TTS providers
STT_PROVIDER=groq-whisper        # whisper | groq-whisper | assemblyai | deepgram
TTS_PROVIDER=elevenlabs          # elevenlabs | openai-tts | piper
DEFAULT_LANGUAGE=en

# Voice settings
WAKE_WORD_ENABLED=true
WAKE_WORDS=hey jarvis,jarvis
WAKE_WORD_SENSITIVITY=0.5
VOICE_SAMPLE_RATE=16000
VOICE_CHUNK_SIZE=1024

# ---------------------------------------------------------------------------
# AI Settings
# ---------------------------------------------------------------------------
DEFAULT_AI_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-6
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=2048

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------
FEATURE_WAKE_WORD=true
FEATURE_VOICE_STREAMING=true
FEATURE_MEMORY_ENABLED=true
FEATURE_PLUGINS_ENABLED=true
FEATURE_MULTI_USER=true
FEATURE_AUDIT_LOG=true
FEATURE_RATE_LIMITING=true
FEATURE_ANALYTICS=false
FEATURE_VOICE_ENABLED=true
FEATURE_AGENTS_ENABLED=true
FEATURE_WEB_SEARCH_ENABLED=true
FEATURE_CODE_EXECUTION_ENABLED=false
FEATURE_COMPUTER_USE_ENABLED=false

# ---------------------------------------------------------------------------
# Code Execution
# ---------------------------------------------------------------------------
ENABLE_CODE_EXECUTION=true

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=20

# ---------------------------------------------------------------------------
# Observability (extended)
# ---------------------------------------------------------------------------
OPENTELEMETRY_ENABLED=false
OPENTELEMETRY_ENDPOINT=http://localhost:4317
LOG_JSON=false

# ---------------------------------------------------------------------------
# Ollama (local LLM)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
STORAGE_BACKEND=local            # local | s3 | gcs
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=25

# AWS S3 (if STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# Email (optional)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourapp.com
SMTP_TLS=true

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
PROMETHEUS_ENABLED=true
SENTRY_DSN=                      # Optional Sentry error tracking
OTEL_EXPORTER_OTLP_ENDPOINT=     # OpenTelemetry collector

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# Frontend (Next.js)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_NAME=JARVIS
NEXTAUTH_SECRET=REPLACE_WITH_RANDOM_STRING
NEXTAUTH_URL=http://localhost:3000
